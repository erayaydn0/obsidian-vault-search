{
  "name": "vault-search",
  "version": "0.1.0",
  "description": "Local-first hybrid semantic search for your Obsidian vault",
  "private": true,
  "main": "main.js",
  "packageManager": "bun@1.3.11",
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "dev": "bun esbuild.config.mjs",
    "build": "bun esbuild.config.mjs production",
    "check": "tsc --noEmit",
    "test": "bun test",
    "test:docker": "bun scripts/test-docker.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/erayaydn0/obsidian-plugin.git"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "search",
    "semantic-search",
    "sqlite"
  ],
  "author": "VaultSearch Contributors",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/erayaydn0/obsidian-plugin/issues"
  },
  "homepage": "https://github.com/erayaydn0/obsidian-plugin#readme",
  "dependencies": {
    "@huggingface/transformers": "^4.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.2",
    "@types/sql.js": "^1.4.11",
    "esbuild": "^0.28.0",
    "esbuild-svelte": "^0.9.4",
    "obsidian": "^1.12.3",
    "svelte": "^5.55.1",
    "svelte-preprocess": "^6.0.3",
    "typescript": "^6.0.2"
  }
}
